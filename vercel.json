{
    "builds": [
        {
            "src": "api/test.py",
            "use": "@vercel/python",
            "config": {
                "installCommand": "pip install -r requirements-vercel.txt"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/test.py"
        }
    ]
}