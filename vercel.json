{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "pythonVersion": "3.11",
                "includeFiles": [
                    "web/**/*",
                    "spotify/**/*",
                    "audio/**/*",
                    "requirements.txt"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.py"
        }
    ]
}