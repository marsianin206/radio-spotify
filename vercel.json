{
    "builds": [
        {
            "src": "web/app.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/web/app.py"
        }
    ],
    "functions": {
        "web/app.py": {
            "runtime": "python3.9"
        }
    }
}